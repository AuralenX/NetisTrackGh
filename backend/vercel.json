{
  "version": 2,
  "buildCommand": "npm install",
  "installCommand": "npm ci",
  "framework": "express",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/:path(.*)",
      "destination": "/api/server.js"
    }
  ]
}
